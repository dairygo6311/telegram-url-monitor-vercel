{
  "functions": {
    "api/webhook.py": {
      "runtime": "python3.11",
      "maxDuration": 30
    },
    "api/monitor.py": {
      "runtime": "python3.11",
      "maxDuration": 60
    },
    "api/index.py": {
      "runtime": "python3.11",
      "maxDuration": 10
    },
    "api/setup_webhook.py": {
      "runtime": "python3.11",
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/webhook", "dest": "/api/webhook.py" },
    { "src": "/api/monitor", "dest": "/api/monitor.py" },
    { "src": "/api/setup", "dest": "/api/setup_webhook.py" },
    { "src": "/(.*)", "dest": "/api/index.py" }
  ],
  "crons": [
    {
      "path": "/api/monitor",
      "schedule": "* * * * *"
    }
  ]
}
